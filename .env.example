# Copy this file to ".env" and fill in your real key.
#   cp .env.example .env
# Get a key at https://console.anthropic.com  (never commit the real .env)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Which Claude model the agent uses.
#   claude-haiku-4-5  -> cheap + fast, great while learning
#   claude-opus-4-8   -> strongest reasoning, for the polished version
MAINTENANCE_MODEL=claude-haiku-4-5
